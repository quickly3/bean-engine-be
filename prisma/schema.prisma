// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

model BiliUps {
  id              Int       @id @default(autoincrement())
  mid             BigInt?   @db.BigInt
  attribute       Int       @default(0)
  mtime           BigInt    @db.BigInt
  tag             Int[]     @default([])
  special         Int       @default(0)
  uname           String
  face            String
  sign            String
  face_nft        Int       @default(0)
  handle          String?
  name_render     Json?     @db.Json
  contract_info   Json?     @db.Json
  official_verify Json?     @db.Json
  nft_icon        String?   @default("")
  rec_reason      String?   @default("")
  track_id        String?   @default("")
  follow_time     String?   @default("")
  following       BigInt?   @default(0) @db.BigInt
  follower        BigInt?   @default(0) @db.BigInt
  likes           BigInt?   @default(0) @db.BigInt
  view            BigInt?   @default(0) @db.BigInt
  totalVideos     Int?      @default(0)
  crawlStatus     String?   @default("pending")
  createdAt       DateTime? @default(now())
  updatedAt       DateTime? @default(now()) @updatedAt

  @@index([mid])
  @@schema("public")
}

model BiliVideos {
  id           Int      @id @default(autoincrement())
  title        String?
  subtitle     String?
  description  String?
  tname        String?
  tname_v2     String?
  comment      Int?
  typeid       Int?
  play         Int?
  pic          String?
  copyright    String?
  review       Int?
  author       String?
  mid          BigInt   @db.BigInt
  created      Int?
  length       String?
  video_review Int?
  aid          BigInt?
  bvid         String?
  season_id    Int?
  danmaku      Int?     @default(0)
  favorite     Int?     @default(0)
  coin         Int?     @default(0)
  share        Int?     @default(0)
  now_rank     Int?     @default(0)
  his_rank     Int?     @default(0)
  like         BigInt?  @default(0) @db.BigInt
  dislike      Int?     @default(0)
  evaluation   String?  @default("")
  vt           Int?     @default(0)
  viewseo      BigInt?  @default(0) @db.BigInt
  state        String?  @default("init")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([mid])
  @@index([bvid])
  @@index([aid])
  @@schema("public")
}

model VideoHonors {
  id                   Int      @id @default(autoincrement())
  mid                  BigInt   @db.BigInt
  bvid                 String?
  aid                  BigInt   @db.BigInt
  type                 Int?
  desc                 String?
  weekly_recommend_num Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now()) @updatedAt

  @@index([mid])
  @@index([bvid])
  @@index([aid])
  @@schema("public")
}

model BiliUpAnalysis {
  id      Int     @id @default(autoincrement())
  mid     BigInt? @db.BigInt
  type    String?
  content String?

  @@index([mid])
  @@schema("public")
}

model HackNews {
  id           Int      @id
  state        String?
  by           String?
  descendants  Int?     @default(0)
  score        Int?     @default(0)
  time         Int?
  title        String?
  subTitle     String?
  title_cn     String?
  category     String?
  sub_category String?
  level        Int?
  text         String?
  text_cn      String?
  type         String?
  url          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([type])
  @@index([time])
  @@schema("public")
}

model WbgDataSource {
  id                   Int     @id @default(autoincrement())
  lastupdated          String?
  name                 String?
  name_cn              String?
  code                 String?
  databid              String?
  description          String?
  url                  String?
  dataavailability     String?
  metadataavailability String?
  concepts             String?

  @@index([code])
  @@schema("public")
}

model WbgIndicator {
  id        Int     @id @default(autoincrement())
  sourceId  Int?
  indicator String?
  value     String?
  value_cn  String?

  @@index([value])
  @@index([sourceId])
  @@schema("public")
}

model WbgCountry {
  id                      String   @id
  iso2Code                String?  @unique
  name                    String?
  regionId                String?
  regionIso2Code          String?
  regionValue             String?
  adminRegionId           String?
  adminRegionIso2Code     String?
  adminRegionValue        String?
  incomeLevelId           String?
  incomeLevelIso2Code     String?
  incomeLevelValue        String?
  lendingTypeId           String?
  lendingTypeIso2Code     String?
  lendingTypeValue        String?
  capitalCity             String?
  longitude               String?
  latitude                String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @default(now()) @updatedAt

  @@index([name])
  @@index([regionId])
  @@index([adminRegionId])
  @@index([incomeLevelId])
  @@index([lendingTypeId])
  @@schema("public")
}

// 观察者网·风闻社区 作者
model GuanUser {
  uid            String    @id
  nickname       String?
  title          String?
  level          String?
  avatar         String?
  articleCount   Int?      @default(0)
  replyCount     Int?      @default(0)
  beRepliedCount Int?      @default(0)
  likeCount      Int?      @default(0)
  collectCount   Int?      @default(0)
  crawlStatus    String?   @default("pending")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  @@index([nickname])
  @@schema("public")
}

// 观察者网·风闻社区 文章
model GuanArticle {
  articleId    String    @id
  authorUid    String?
  authorNick   String?
  title        String?
  summary      String?
  content      String?
  images       String[]  @default([])
  publishTime  DateTime?
  location     String?
  likeCount    Int?      @default(0)
  viewCount    Int?      @default(0)
  commentCount Int?      @default(0)
  url          String?
  state        String?   @default("pending")
  // AI 衍生字段
  category     String?
  aiSummary    String?
  sentiment    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  @@index([authorUid])
  @@index([publishTime])
  @@index([state])
  @@schema("public")
}

// 观察者网·风闻社区 评论
model GuanComment {
  id           String    @id
  articleId    String
  commenterUid String?
  commenter    String?
  content      String?
  time         DateTime?
  location     String?
  upCount      Int?      @default(0)
  downCount    Int?      @default(0)
  createdAt    DateTime  @default(now())

  @@index([articleId])
  @@schema("public")
}
